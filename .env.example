# ═══════════════════════════════════════════════════════════════════
# SDIA — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit the .env file to the repository
# ═══════════════════════════════════════════════════════════════════

# ── BACKEND (Node.js) ───────────────────────────────────────────────

# Azure Cosmos DB
# Local dev: uses the emulator (see docker-compose.yml)
# Production: uses Managed Identity (COSMOS_KEY not needed)
COSMOS_ENDPOINT=https://localhost:8081
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMcZcLU==
COSMOS_DB_NAME=sdia
COSMOS_CONTAINER=audit-jobs

# Azure Communication Services
# Local dev: use Mailhog (emails appear at http://localhost:8025)
# Production: real ACS connection string
ACS_CONNECTION_STRING=endpoint=https://[YOUR-ACS].communication.azure.com;accesskey=[YOUR-KEY]

# JWT — Local dev only; in production comes from Azure Key Vault
JWT_SECRET=change-this-in-production-use-keyvault-minimum-64-characters

# App config
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,https://[YOUR-ORG].github.io
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=3600000

# Azure Key Vault (production only)
# AZURE_KEYVAULT_URL=https://sdia-kv.vault.azure.net/

# ── ORCHESTRATOR (Python) ───────────────────────────────────────────

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://[YOUR-RESOURCE].openai.azure.com/
AZURE_OPENAI_API_KEY=                    # Local dev only; production uses Managed Identity
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure Blob Storage (temporary PDFs)
# Local dev: use Azurite (see docker-compose.yml)
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UKvz1KFGVcZOTCgb=;BlobEndpoint=http://localhost:10000/devstoreaccount1;
BLOB_CONTAINER_NAME=sdia-reports

# PDF Protection
# Owner password (managed internally, never exposed to the user)
PDF_OWNER_SECRET=change-this-in-production

# OSINT Config
OSINT_REQUEST_TIMEOUT_S=15
OSINT_MAX_CONCURRENT=3
OSINT_USER_AGENT=SDIA-Educational-Bot/0.1 (+https://github.com/[org]/self-digital-identity-audit)

# Dev helpers
USE_LLM_MOCK=false    # true = use fixtures instead of real Azure OpenAI

# ── FRONTEND (Vite) ─────────────────────────────────────────────────
# Create frontend/.env.local with:
# VITE_API_URL=http://localhost:3000

# ── GITHUB ACTIONS (repository secrets) ────────────────────────────
# The following are configured as GitHub Secrets, not in this file:
# AZURE_CLIENT_ID          → OIDC Federated Credential
# AZURE_TENANT_ID          → OIDC Federated Credential
# AZURE_SUBSCRIPTION_ID    → OIDC Federated Credential
# ACR_LOGIN_SERVER         → Azure Container Registry
# ACA_RESOURCE_GROUP       → Resource group name
# COSMOS_ACCOUNT_NAME      → Cosmos DB account name (for CLI queries)
